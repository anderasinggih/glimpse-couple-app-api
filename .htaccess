<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # WebSocket Reverse Proxy to Reverb (port 8080)
    RewriteCond %{HTTP:Upgrade} =websocket [NC]
    RewriteRule ^app/(.*) ws://127.0.0.1:8080/app/$1 [P,L]
    
    RewriteCond %{HTTP:Upgrade} !=websocket [NC]
    RewriteRule ^app/(.*) http://127.0.0.1:8080/app/$1 [P,L]
    
    # 1. BLOKIR AKSES LANGSUNG KE FILE SENSITIF LARAVEL (KEAMANAN MUTLAK)
    RedirectMatch 403 /\.(key|env|git|json|yml|yaml)$
    RedirectMatch 403 ^/composer\.(json|lock)$
    RedirectMatch 403 ^/package\.(json|lock)$
    RedirectMatch 403 ^/artisan$
    RedirectMatch 403 ^/bootstrap/
    RedirectMatch 403 ^/config/
    RedirectMatch 403 ^/database/
    RedirectMatch 403 ^/resources/
    RedirectMatch 403 ^/routes/
    RedirectMatch 403 ^/tests/
    RedirectMatch 403 ^/vendor/

    # 2. ALIKHAN SEMUA TRAFIK WEB KE SUBFOLDER /public SECARA OTOMATIS
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
